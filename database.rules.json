{
    "rules": {
        "sessions": {
            ".read": true,
            ".write": true,
            "$date": {
                ".indexOn": ["score"]
            }
        },
        "games": {
            ".read": true,
            ".write": true,
            ".indexOn": ["score", "timestamp"]
        },
        "metrics": {
            ".read": true,
            ".write": true
        }
    }
}
